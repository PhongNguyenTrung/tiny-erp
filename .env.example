# Script Properties for tiny-erp
# Apps Script does NOT load this file — copy values manually into
#   Apps Script editor → ⚙ Project Settings → Script Properties.
# This file documents the full property surface for the public repo.

# === REQUIRED ===

# Gemini API key (https://ai.google.dev → Get API key)
GEMINI_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Google Sheets template ID. Auto-populated by setup_createTemplate(),
# or paste manually if you reuse an existing template.
TEMPLATE_SPREADSHEET_ID=

# === STRONGLY RECOMMENDED (security) ===

# Random token embedded in webhook URL as ?token=…
# Generate via setup_generateWebhookSecret() — DO NOT commit a real value.
TELEGRAM_WEBHOOK_SECRET=

# Comma-separated Telegram user IDs allowed to use the bot.
# Find yours by messaging @userinfobot on Telegram.
# Leave empty ONLY for local dev — without it, anyone who finds the bot can
# burn your Gemini quota.
TELEGRAM_ALLOWED_USER_IDS=

# === OPTIONAL ===

# Defaults to gemini-2.5-flash. Run selftest_listGeminiModels to see what
# your key has access to.
GEMINI_MODEL=

# Defaults to BaoGia. Tab name inside template.
TEMPLATE_SHEET_NAME=

# Drive folder ID to store generated PDFs + per-quote Sheet copies.
# Strongly recommend a dedicated folder you control access to.
OUTPUT_DRIVE_FOLDER_ID=

# VAT rate, defaults to 0.08 (8%).
VAT_RATE=

# Max characters of inbound message forwarded to Gemini (default 4000).
MAX_INPUT_CHARS=

# Set to "true" to make generated PDFs shareable via ANYONE_WITH_LINK.
# Off by default — PDFs contain customer PII (name, phone, prices).
PUBLIC_PDF_SHARING=

# === LEGACY (Zalo OA path, kept for reference) ===
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_REFRESH_TOKEN=
ZALO_APP_ID=
ZALO_APP_SECRET=
